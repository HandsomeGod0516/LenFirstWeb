PORT=3000

# MySQL — docker (infra-docker/docker-compose.yml 讀)
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=lenbot_db

# portal-main 連 MySQL (值與上面 MYSQL_* 一致)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=lenbot_db

# Session signing key — 產生範例：openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Local Ollama — 統一走 gemma4:31b (文字+圖片+摘要全包)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:31b

# Email (可選；不設只會 log，不寄信)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=lenbot <you@gmail.com>
# PUBLIC_URL=https://lenbotai.com
